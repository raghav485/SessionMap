{
  "name": "sessionmap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "sessionmap": "dist/cli.js"
  },
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build --config vite.web.config.ts",
    "build": "npm run build:server && npm run build:web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:mcp": "npm run build && node scripts/run-vitest.mjs run --testTimeout=15000 test/mcp",
    "test": "npm run build && node scripts/run-vitest.mjs run --testTimeout=15000",
    "test:web": "npm run build && playwright test",
    "verify": "npm run lint && npm run typecheck && npm run test:mcp && npm run test && npm run test:web"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "chokidar": "^4.0.3",
    "commander": "^14.0.2",
    "d3": "^7.9.0",
    "fastify": "^5.6.1",
    "ignore": "^7.0.5",
    "web-tree-sitter": "^0.25.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.56.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.38.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
